# Force www and HTTPS — the Cloudflare Worker only accepts requests from
# https://www.sidehustle.llc, so anyone landing on the bare domain hits a
# CORS rejection at checkout. Redirecting at the host level also collapses
# duplicate-content URLs for SEO.
RewriteEngine On
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^sidehustle\.llc$ [NC]
RewriteRule ^(.*)$ https://www.sidehustle.llc/$1 [R=301,L]

# Ensure JavaScript files are served with correct MIME type
# Required for ES modules (type="module") which strictly enforce MIME checking
AddType application/javascript .js .mjs

# Prevent caching of HTML files — always check for updates
<FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>

# Cache static assets for 1 year (cache busting handles versioning)
<FilesMatch "\.(css|js|webp|png|jpg|jpeg|gif|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Auto-generated data files must not be cached immutably because ES module
# import statements (e.g. import from './gallery-data.js') have no ?v= param.
# Without this, browsers serve stale data after new items are added.
<FilesMatch "(gallery-data|blog-data)\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>

# CSS partials loaded via @import can't carry ?v= cache busters reliably
# across all mobile browsers, so prevent immutable caching on all CSS files.
<FilesMatch "\.css$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>
